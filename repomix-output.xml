                </span>
              )}
            </div>
            
            {/* Collapse toggle (only desktop triggers) */}
            <button 
              onClick={() => setIsSidebarOpen(!isSidebarOpen)}
              className="p-1 rounded text-slate-400 hover:text-white hover:bg-slate-800 transition-colors hidden md:block"

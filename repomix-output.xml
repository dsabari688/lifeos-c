    let highlightedEntity = "None";
    if (activeContext?.selectedTaskName) {
      highlightedEntity = `Task '${activeContext.selectedTaskName}' (ID: ${activeContext.selectedTaskId})`;
    } else if (activeContext?.selectedHabitName) {

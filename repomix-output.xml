    (totalFocusMinLastWeek / 300) * 30 + 
    (stressCount * 12) + 
    (80 - sleepScore)
  )));

  return {
    healthScore,
    consistency,
    momentum,
    goalProgress,
    energy,
    burnoutRisk,
    energyData
  };
}


      </div>

      {/* Right Tab workspace content card (8 cols) */}
      <div className="lg:col-span-8 bg-white rounded-2xl border border-slate-100 p-6 shadow-xs min-h-[480px]">
        
        {/* Personal Form Tab */}
        {activeTab === "personal" && (

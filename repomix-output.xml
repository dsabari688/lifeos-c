<file path="client/src/index.css">
@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap');
@import "tailwindcss";

@theme {
  --font-sans: "Plus Jakarta Sans", "Inter", ui-sans-serif, system-ui, sans-serif;
  --font-display: "Space Grotesk", sans-serif;
  --font-mono: "JetBrains Mono", monospace;
}

@keyframes jarvis-breath {
  0%, 100% {
    transform: scale(1);
    box-shadow: 0 0 20px rgba(245, 166, 35, 0.3), inset 0 0 15px rgba(245, 166, 35, 0.2);
  }
  50% {
    transform: scale(1.08);
    box-shadow: 0 0 45px rgba(245, 166, 35, 0.6), inset 0 0 25px rgba(245, 166, 35, 0.4);
  }
}

@keyframes jarvis-rotate-clockwise {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

@keyframes jarvis-rotate-counter {
  0% { transform: rotate(360deg); }
  100% { transform: rotate(0deg); }
}

@keyframes jarvis-ripple {
  0% {
    transform: scale(0.9);
    opacity: 0.8;
  }
  100% {
    transform: scale(1.8);
    opacity: 0;
  }
}

@keyframes jarvis-pulse-ring {
  0% {
    transform: scale(0.95);
    opacity: 0.5;
  }
  50% {
    transform: scale(1.25);
    opacity: 0.7;
  }
  100% {
    transform: scale(0.95);
    opacity: 0.5;
  }
}

@keyframes jarvis-wave {
  0%, 100% { transform: scaleY(0.3); }
  50% { transform: scaleY(1.3); }
}

@keyframes float-gentle {
  0%, 100% { transform: translateY(0px) rotate(0deg); }
  50% { transform: translateY(-8px) rotate(1deg); }
}

.animate-jarvis-breath {
  animation: jarvis-breath 3s ease-in-out infinite;
}

.animate-jarvis-rotate {
  animation: jarvis-rotate-clockwise 12s linear infinite;
}

.animate-jarvis-rotate-counter {
  animation: jarvis-rotate-counter 8s linear infinite;
}

.animate-jarvis-ripple {
  animation: jarvis-ripple 2s cubic-bezier(0.1, 0.8, 0.3, 1) infinite;
}

.animate-jarvis-pulse-ring {
  animation: jarvis-pulse-ring 2.5s ease-in-out infinite;
}

.animate-jarvis-wave-1 { animation: jarvis-wave 1s ease-in-out infinite; }
.animate-jarvis-wave-2 { animation: jarvis-wave 0.7s ease-in-out infinite; animation-delay: 0.15s; }
.animate-jarvis-wave-3 { animation: jarvis-wave 1.2s ease-in-out infinite; animation-delay: 0.3s; }
.animate-jarvis-wave-4 { animation: jarvis-wave 0.8s ease-in-out infinite; animation-delay: 0.45s; }
.animate-jarvis-wave-5 { animation: jarvis-wave 1.1s ease-in-out infinite; animation-delay: 0.6s; }

.animate-float-gentle {
  animation: float-gentle 6s ease-in-out infinite;
}

/* Elegant light custom scrollbar matching clean mockup */
::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}
::-webkit-scrollbar-track {
  background: rgba(241, 243, 245, 0.8);
}
::-webkit-scrollbar-thumb {
  background: rgba(218, 224, 233, 0.8);
  border-radius: 6px;
}
::-webkit-scrollbar-thumb:hover {
  background: rgba(245, 166, 35, 0.5);

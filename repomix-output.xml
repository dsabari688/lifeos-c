        source: sleepNodeId,
        target: moodNodeId,
        relationship: "depresses_mood"
      });
    }
  }

  // 6. Add Memories Nodes
  aiMemory.slice(-5).forEach((m: any) => {
    nodes.push({ id: m.id, type: 'memory', label: m.fact });
  });

  return {
    nodes,
    edges
  };

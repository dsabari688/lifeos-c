                  const res = await fetch("/api/piggy/memory", {
                    method: "POST",
                    headers: {
                      ...headers,
                      "Content-Type": "application/json"
                    },
                    body: JSON.stringify({ fact, category })
                  });
                  const data = await res.json();
                  if (data.success) {
                    setDashboardData((prev: any) => ({
                      ...prev,
                      aiMemory: [...(prev.aiMemory || []), data.fact]
                    }));
                    form.reset();
                  }

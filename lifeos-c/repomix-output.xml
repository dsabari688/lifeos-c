@keyframes jarvis-breath {
  0%, 100% {
    transform: scale(1);
    box-shadow: 0 0 20px rgba(245, 166, 35, 0.3), inset 0 0 15px rgba(245, 166, 35, 0.2);
  }
  50% {
    transform: scale(1.08);
    box-shadow: 0 0 45px rgba(245, 166, 35, 0.6), inset 0 0 25px rgba(245, 166, 35, 0.4);
  }
}

@keyframes jarvis-rotate-clockwise {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

@keyframes jarvis-rotate-counter {
  0% { transform: rotate(360deg); }
  100% { transform: rotate(0deg); }
}

@keyframes jarvis-ripple {
  0% {
    transform: scale(0.9);
    opacity: 0.8;
  }
  100% {
    transform: scale(1.8);
    opacity: 0;
  }
}

@keyframes jarvis-pulse-ring {
